# Bluesky credentials
BLUESKY_HANDLE=           # e.g. seanxavier.bsky.social
BLUESKY_APP_PASSWORD=     # from bsky.app → Settings → App Passwords

# AI
ANTHROPIC_API_KEY=

# Brand voice — absolute path to SX_Instructions.md
BRANDVOICE_PATH=

# Creator detection — which signals to use when classifying a replier as a creator.
# For personal accounts (Sean): enable only mutual_follow (you only follow creators).
# For the template: enable all three; two signals required to classify.
CREATOR_DETECTION_MUTUAL_FOLLOW=true
CREATOR_DETECTION_BIO=false
CREATOR_DETECTION_FOLLOWER_COUNT=false
CREATOR_FOLLOWER_THRESHOLD=500   # minimum followers to trigger follower_count signal
COLLAB_DM_THRESHOLD=20000        # minimum followers to offer collab DM pull

# Fan discount — offered in both proactive DMs and reply-thread DM pulls
FAN_DISCOUNT_CODE=Fans50                                  # discount code
FAN_DISCOUNT_URL_REPLY=https://go.seanxavier.com/bdmp     # reply-sourced DMs
FAN_DISCOUNT_URL_LIKE=https://go.seanxavier.com/bdml      # like-sourced DMs
FAN_DISCOUNT_URL_REPOST=https://go.seanxavier.com/bdmr    # repost-sourced DMs
MAX_DISCOUNTS_PER_DAY=5                                   # cap for reply-thread discount sends
# Legacy: DISCOUNT_OFFER= is still read if FAN_DISCOUNT_CODE is not set

# DM feature — proactive DMs on likes/reposts
DM_ENABLED=true          # set to false to disable entirely
DM_STATE_PATH=           # override default dm_state.json location
STATE_PATH=              # override default state.json location
CLASSIFICATION_TTL_DAYS=30  # how long to cache fan/creator/themed/studio classification
DAILY_DM_CAP=50          # max outreach DMs per day (follow queue path)
MAX_CONVERSATION_DEPTH=3 # follow-up rounds before forcing DM pull in reply threads

# User type detection — manual handle lists (no @, comma-separated)
STUDIO_HANDLES=          # e.g. men.bsky.social,nakedsword.bsky.social
THEMED_HANDLES=          # e.g. geekgooner.bsky.social

# Audience discovery
DISCOVERY_CREATOR_HANDLE=            # your Bluesky handle — whose followers to prefetch
DISCOVERY_DOMAIN_KEYWORDS=           # comma-separated keywords e.g. "gay fitness,muscle"
DISCOVERY_DOMAINS=                   # comma-separated domain labels e.g. "fitness,muscle"
DAILY_COMMENT_CAP=50                 # max comments posted per day (comment_engine.py)

# GCP / Firebase
GOOGLE_CLOUD_PROJECT=sx-platform
FIRESTORE_DATABASE=sxplatformdatabase  # Firestore database name (not "default")

# Dashboard API (web/api/main.py)
DASHBOARD_SECRET=             # Bearer token for all /api/* endpoints
MONTHLY_SPEND_CAP_USD=        # Optional budget cap; amber at 80%, red at 100%
